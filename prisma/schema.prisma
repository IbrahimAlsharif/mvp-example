// Human Timeline Network — data model.
//
// Load-bearing invariants encoded here:
//  - PrivacyCircle has FOUR values (US-3.1, extended): ME_ONLY, FAMILY,
//    PUBLIC_UNLISTED (link-only — direct reads denied, reachable only via a valid
//    share-link token), and PUBLIC. PUBLIC is directly viewable by ANY
//    AUTHENTICATED account (no connection required) but is NOT discoverable to
//    logged-out visitors. PUBLIC is the only circle whose cross-account read is
//    granted without a connection — see decideAccess / visibilityClauses.
//  - Event.circle and Event.legacyConsent are COLUMNS on the Event row, so they
//    commit in the same single-row insert as the event — circle/consent can never
//    be missing from a persisted event (US-3.1 AC-9, US-1.1 AC-7, guardrail G5).
//  - Event.deletedAt / Media.deletedAt are nullable timestamps: deletes are soft
//    and recoverable; nothing is hard-deleted by a system event (G2, US-1.1 AC-16).
//  - Media.publicId is the only client-facing id (128-bit, non-guessable). The
//    content-addressed storageKey is never exposed to clients (US-3.3 AC-1).
//  - @@unique([eventId, checksumSha256]) on Media => exactly one blob per item
//    even under resume/retry (US-1.2 AC-13).
//  - Event.submitKey @unique => idempotent submit (US-1.1 AC-8).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PrivacyCircle {
  ME_ONLY
  FAMILY
  PUBLIC_UNLISTED
  PUBLIC
}

enum AccountStatus {
  UNCONFIRMED
  ACTIVE
}

// Per-item legacy-consent decision (US-4.1). Tri-state: GRANTED / DENIED record
// an explicit owner choice; UNSET is the default and is treated IDENTICALLY to
// DENIED (silence = no future heir access). Captured + exported only — NO code
// path reads this to grant access at MVP (inheritance is deferred, G9).
enum LegacyConsent {
  UNSET
  GRANTED
  DENIED
}

// A connection's tier governs which of an author's events a counterpart can see
// (US — social graph). FAMILY can see the author's FAMILY + PUBLIC_UNLISTED
// events; GENERAL can see only PUBLIC_UNLISTED. ME_ONLY is never shared. This
// maps onto PrivacyCircle without duplicating it: the circle stays the per-event
// label, the tier is the per-relationship grant.
enum ConnectionTier {
  FAMILY
  GENERAL
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum MediaType {
  PHOTO
  VIDEO
  VOICE
}

enum MediaStatus {
  PENDING
  PERSISTED
  FAILED
}

model Invitation {
  id         String    @id @default(cuid())
  token      String    @unique // >=128-bit, single-use (US-0.1 AC-1)
  email      String? // optional email-pinned invite
  expiresAt  DateTime
  consumedAt DateTime? // single-use: set inside the account-create transaction
  createdAt  DateTime  @default(now())
  account    Account?

  @@index([email])
}

model Account {
  id            String        @id @default(cuid())
  email         String        @unique // duplicate-account prevention (US-0.1 AC-6)
  displayName   String? // human-facing name shown in the UI; falls back to email local-part when null
  passwordHash  String? // null for social-only accounts
  status        AccountStatus @default(UNCONFIRMED)
  defaultCircle PrivacyCircle @default(ME_ONLY) // G1 / US-0.1 AC-8
  invitationId  String?       @unique
  invitation    Invitation?   @relation(fields: [invitationId], references: [id])
  createdAt     DateTime      @default(now())

  identities AuthIdentity[]
  sessions   Session[]
  events     Event[]
  tokens     EmailToken[]

  // Social graph. A Connection is stored ONCE per unordered pair with
  // accountAId < accountBId (canonical ordering), so these two back-relations
  // are disambiguated by relation name, not by direction-as-meaning.
  connectionsA Connection[] @relation("ConnectionA")
  connectionsB Connection[] @relation("ConnectionB")
  sentRequests Connection[] @relation("ConnectionRequester")

  moderationCases ModerationCase[]
  capsules        Capsule[]
}

// An accepted or pending link between two accounts (the social graph edge).
//
// Invariants:
//  - Exactly one row per unordered pair: callers MUST store it with
//    accountAId < accountBId (lexicographic on cuid). @@unique enforces no dup.
//  - `tier` is the visibility grant (see ConnectionTier); it applies SYMMETRICALLY
//    once ACCEPTED — both sides see each other's events at that tier.
//  - `requestedById` records who initiated, so accept/decline knows which side
//    is the pending recipient (the OTHER account of the pair).
//  - A self-connection is meaningless and must be rejected by the accessor layer.
model Connection {
  id            String           @id @default(cuid())
  accountAId    String // canonical low id
  accountA      Account          @relation("ConnectionA", fields: [accountAId], references: [id], onDelete: Cascade)
  accountBId    String // canonical high id
  accountB      Account          @relation("ConnectionB", fields: [accountBId], references: [id], onDelete: Cascade)
  tier          ConnectionTier   @default(GENERAL)
  status        ConnectionStatus @default(PENDING)
  requestedById String // which account sent the request (one of A/B)
  requestedBy   Account          @relation("ConnectionRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())
  acceptedAt    DateTime? // set when status flips to ACCEPTED
  updatedAt     DateTime         @updatedAt

  @@unique([accountAId, accountBId]) // one edge per unordered pair
  @@index([accountAId, status])
  @@index([accountBId, status])
  @@index([requestedById])
}

model AuthIdentity {
  id          String       @id @default(cuid())
  accountId   String
  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider    AuthProvider
  providerSub String // provider subject / verified email
  createdAt   DateTime     @default(now())

  @@unique([provider, providerSub])
  @@index([accountId])
}

model EmailToken {
  id        String    @id @default(cuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  token     String    @unique // >=128-bit, non-guessable
  purpose   String // "confirm" | "reset"
  expiresAt DateTime
  usedAt    DateTime? // single-use (US-0.1 AC-2, AC-7)
  createdAt DateTime  @default(now())

  @@index([accountId])
}

model Session {
  id        String    @id @default(cuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // store the HASH of the cookie token, never the raw token
  expiresAt DateTime
  revokedAt DateTime? // server-side sign-out invalidation (US-0.1 AC-9)
  createdAt DateTime  @default(now())

  @@index([accountId])
}

model Event {
  id            String        @id @default(cuid())
  accountId     String
  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  note          String? // text note; note-only event is valid
  occurredOn    DateTime // canonical absolute Gregorian date (US-1.1 AC-5)
  locationLat   Float?
  locationLng   Float?
  placeName     String? // structured free-text place (J2.4); stored on its own column, NOT folded into the note
  circle        PrivacyCircle @default(ME_ONLY) // ATOMIC with event (US-3.1 AC-9)
  legacyConsent Boolean       @default(false) // legacy boolean (kept; mirrors GRANTED)
  // Tri-state consent + its decision timestamp, committed ATOMICALLY with the
  // event/circle (US-4.1 AC-1/AC-3). UNSET == no heir access (AC-2). Never an
  // access backdoor (AC-8/G9).
  legacyConsentValue LegacyConsent @default(UNSET)
  legacyConsentAt    DateTime? // ISO-8601 decision time, set when GRANTED/DENIED
  submitKey     String        @unique // idempotent submit (US-1.1 AC-8)
  version       Int           @default(1) // versioning seam (US-1.1 AC-16)
  deletedAt     DateTime? // soft-delete / recoverable (G2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  media      Media[]
  shareLinks ShareLink[]

  @@index([accountId, occurredOn])
  @@index([accountId, deletedAt])
}

model Media {
  id             String      @id @default(cuid())
  publicId       String      @unique // >=128-bit non-guessable; ONLY client-facing id (US-3.3 AC-1)
  eventId        String?
  event          Event?      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  accountId      String // owner, for authz before an event is attached
  type           MediaType
  mimeType       String // validated against allowlist (US-1.2 AC-7)
  storageKey     String // content-addressed: "sha256/<hash>"; NEVER exposed to clients
  checksumSha256 String // client-supplied, server-verified at complete (US-1.2 AC-4)
  byteSize       Int?
  status         MediaStatus @default(PENDING) // confirm only on PERSISTED (US-1.2 AC-4)
  deletedAt      DateTime? // soft-delete (G2)
  createdAt      DateTime    @default(now())

  @@unique([eventId, checksumSha256]) // exactly one blob per item per event (US-1.2 AC-13)
  @@index([accountId])
  @@index([status])
}

model UploadSession {
  id             String    @id @default(cuid())
  accountId      String
  uploadKey      String    @unique // client idempotency key (US-1.2 AC-13)
  storageKey     String // target content-addressed key
  s3UploadId     String? // S3/MinIO multipart UploadId
  checksumSha256 String
  mimeType       String
  byteSize       Int?
  lastActivityAt DateTime  @default(now()) // reaper anchor (US-1.2 AC-14)
  completedAt    DateTime? // never reap a completed session (G2)
  createdAt      DateTime  @default(now())

  @@index([completedAt, lastActivityAt])
  @@index([accountId])
}

model ShareLink {
  id        String    @id @default(cuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  token     String    @unique // >=128-bit non-guessable, non-discoverable (US-3.3 AC-5)
  expiresAt DateTime // bounded; default applied if owner sets none (US-3.3 AC-7)
  revokedAt DateTime? // revocation (US-3.3 AC-6)
  createdAt DateTime  @default(now())

  @@index([eventId])
}

// ─── Moderation (US-3.4) ──────────────────────────────────────────────────────
// Human-in-the-loop only. A moderation hold is an ACCESS/VISIBILITY restriction
// layered OVER the durable media store — it NEVER deletes or permanently locks
// the bytes (G2/G3). Restoration is a metadata/access operation, not a re-upload.
// Every account-affecting action passes through lib/moderation/guard, which
// rejects any non-human actor (AC-10). There is NO scanning-driven referral
// pipeline: a case is only ever opened from actual human knowledge.

enum ModerationScope {
  ITEM // a single event/item is access-held
  ACCOUNT // the whole account is access-held (appeal flow stays reachable)
}

enum ModerationStatus {
  OPEN // enqueued from a human report, awaiting human review
  HELD // access hold applied (store untouched)
  APPEALED // owner has appealed; routed back to human review
  CLEARED // review cleared it; access restored intact
  REPORTED // human confirmed; moved to secure preservation store (§2258A(h))
  ESCALATED // target review window elapsed with no decision (never auto-actioned)
}

// `source` is always a human report — no scan source exists. `reviewerId` and the
// timestamps make the human-in-the-loop chain auditable (AC-9). No row here ever
// represents an automated account deletion/lock.
model ModerationCase {
  id          String           @id @default(cuid())
  accountId   String
  account     Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  eventId     String? // null for an account-scope case
  scope       ModerationScope
  status      ModerationStatus @default(OPEN)
  source      String           @default("human_report") // never a scan source (AC-2)
  reviewerId  String? // the human reviewer who last acted (AC-9); never automated
  reviewDueAt DateTime? // target window; on elapse → ESCALATED, never auto-actioned (AC-12)
  appealedAt  DateTime?
  restoredAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  actions ModerationAction[]

  @@index([accountId])
  @@index([status])
}

// Append-only audit trail. Every entry records a HUMAN actor + timestamp; a
// non-human actor can never reach here because the choke point rejects it first.
model ModerationAction {
  id        String         @id @default(cuid())
  caseId    String
  case      ModerationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  actorType String // always "human_reviewer" for an executed action (AC-3/AC-10)
  actorId   String? // the human reviewer's id (audit)
  action    String // hold | clear | restore | report
  createdAt DateTime       @default(now())

  @@index([caseId])
}

// ─── Future Capsules (US-4.2) ─────────────────────────────────────────────────
// A sealed message/media that unlocks on a future DATE only — no death-trigger,
// no heir, no posthumous handoff (G9, date-triggered only). Sealed = immutable
// content + unlock date + recipient. `unlockAtMs` is the absolute instant
// resolved ONCE at seal time from the owner's seal-time timezone offset, so a
// later DST/offset change can never move it earlier (AC-7). Pre-unlock content
// is unreachable (AC-6). Cancel withdraws an unsealed-future capsule (AC-11).

enum CapsuleType {
  MESSAGE
  VIDEO
  LETTER
  GOAL
  PLAN
}

enum CapsuleStatus {
  SEALED // locked, pending its unlock date
  UNLOCKED // unlock date reached; content readable by current recipients
  CANCELLED // owner withdrew it (explicit action, G2)
  UNDELIVERABLE // unlocked but no valid recipient remains (AC-10)
}

model Capsule {
  id                String        @id @default(cuid())
  ownerAccountId    String
  owner             Account       @relation(fields: [ownerAccountId], references: [id], onDelete: Cascade)
  type              CapsuleType
  note              String? // text content (letter/message/goal/plan)
  // Recipient is a circle OR a specific already-invited member (US-3.5). At MVP
  // we target a circle; a removed recipient gains no access at unlock (AC-10).
  recipientCircle   PrivacyCircle @default(FAMILY)
  unlockLocalDay    String // yyyy-mm-dd as the owner entered it
  unlockOffsetMin   Int // owner's seal-time UTC offset (minutes), the authoritative resolver
  unlockAtMs        BigInt // absolute resolved instant (epoch ms); immune to later tz drift
  status            CapsuleStatus @default(SEALED)
  sealedAt          DateTime      @default(now())
  cancelledAt       DateTime?
  createdAt         DateTime      @default(now())

  media CapsuleMedia[]

  @@index([ownerAccountId])
  @@index([status, unlockAtMs])
}

// Capsule media reuses the durable upload pipeline's content-addressed blobs but
// is NOT a timeline Media row (a sealed capsule is not on the timeline). Stored
// content-blind; non-guessable publicId; never served before unlock (AC-6).
model CapsuleMedia {
  id             String   @id @default(cuid())
  capsuleId      String
  capsule        Capsule  @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  publicId       String   @unique
  type           MediaType
  mimeType       String
  storageKey     String
  checksumSha256 String
  createdAt      DateTime @default(now())

  @@index([capsuleId])
}
