# --- Database ---
DATABASE_URL="postgresql://htn:htn@localhost:5432/htn?schema=public"

# --- Object storage (MinIO locally; any S3-compatible in prod) ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="htn-media"
S3_FORCE_PATH_STYLE="true"          # required for MinIO

# --- Media URL security (US-3.3) ---
MEDIA_GET_TTL_SECONDS="600"         # presigned GET expiry, must be <= 600 (10 min)
SHARE_LINK_DEFAULT_TTL_HOURS="168"  # bounded default if owner sets no expiry

# --- Upload reaper (US-1.2 AC-14) ---
UPLOAD_ABANDON_THRESHOLD_HOURS="48" # must exceed any realistic resume window

# --- Sessions / auth (US-0.1) ---
SESSION_TTL_DAYS="30"
APP_URL="http://localhost:3000"

# Google OAuth (Arctic). Leave blank in dev to disable the social button.
OAUTH_GOOGLE_CLIENT_ID=""
OAUTH_GOOGLE_CLIENT_SECRET=""

# Email delivery. In dev, leave blank to log confirmation/reset links to console.
RESEND_API_KEY=""
EMAIL_FROM="Human Timeline <noreply@localhost>"

# AI compose (events/new). Leave blank to use the local heuristic stub; set a key
# to switch the compose endpoint to real Claude. See docs/ai-compose.md.
ANTHROPIC_API_KEY=""
AI_MODEL="claude-haiku-4-5-20251001"
